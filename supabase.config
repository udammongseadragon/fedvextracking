# Supabase configuration template
#
# Keep real values in your deployment environment. Never commit a service-role
# key or other server-side secret to this frontend repository.

# Vite reads the actual browser configuration from .env.local. This file only
# documents the intended resource names.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Non-sensitive application resources
SUPABASE_SHIPMENTS_TABLE=shipments
SUPABASE_SUBMISSIONS_TABLE=payment_submissions
SUPABASE_DOCUMENTS_BUCKET=shipment-documents

# The frontend should only store references/statuses such as provider payment
# IDs, tracking numbers, timestamps, and review states. Payment credentials and
# gift-card codes must be handled by a regulated payment provider, not Supabase.
